# Node Environment
NODE_ENV=development
PORT=3000
HOST=localhost

# TigerGraph Configuration
#
# Option 1: TigerGraph Cloud (Recommended)
# TIGERGRAPH_HOST=https://YOUR-SOLUTION-NAME.i.tgcloud.io
# TIGERGRAPH_USERNAME=tigergraph
# TIGERGRAPH_PASSWORD=your_cloud_password
# TIGERGRAPH_GRAPH_NAME=OdoShield
# TIGERGRAPH_API_TOKEN=your_api_token_from_cloud
#
# Option 2: Local Docker Instance
TIGERGRAPH_HOST=http://localhost:14240
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=tigergraph
TIGERGRAPH_GRAPH_NAME=fraud_detection
TIGERGRAPH_API_TOKEN=
TIGERGRAPH_TIMEOUT=30000

# Logging
LOG_LEVEL=info

# CORS - Allowed origins for frontend
CORS_ORIGIN=http://localhost:5173, http://localhost:8080
